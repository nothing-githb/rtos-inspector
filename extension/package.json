{
  "name": "rtos-inspector",
  "displayName": "Debug Inspector",
  "description": "Visualize your own C/C++ data structures — threads, semaphores, mutexes, queues, linked lists, any struct collection — as live, sortable tables while debugging with GDB. Config-driven and read-only.",
  "version": "0.30.0",
  "publisher": "halistahasahin",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Halis Taha Sahin"
  },
  "homepage": "https://github.com/nothing-githb/rtos-inspector#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nothing-githb/rtos-inspector.git"
  },
  "bugs": {
    "url": "https://github.com/nothing-githb/rtos-inspector/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers",
    "Visualization"
  ],
  "keywords": [
    "gdb",
    "cppdbg",
    "debug",
    "embedded",
    "rtos",
    "thread",
    "semaphore",
    "mutex",
    "queue",
    "linked-list",
    "struct",
    "data-structures",
    "visualize",
    "c",
    "c++"
  ],
  "galleryBanner": {
    "color": "#1E212C",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onDebug"
  ],
  "contributes": {
    "commands": [
      {
        "command": "rtosInspector.open",
        "title": "Debug Inspector: Open Panel"
      },
      {
        "command": "rtosInspector.showLog",
        "title": "Debug Inspector: Show Log"
      }
    ],
    "configuration": {
      "title": "Debug Inspector",
      "properties": {
        "rtosInspector.configPath": {
          "type": "string",
          "default": "rtos-inspector.json",
          "description": "Path to the config file. Absolute paths are used as-is; a relative path is resolved against the workspace root."
        },
        "rtosInspector.logLevel": {
          "type": "string",
          "enum": [
            "off",
            "info",
            "debug"
          ],
          "default": "info",
          "enumDescriptions": [
            "No logging.",
            "General milestones plus warnings/errors: activate, refresh, selection, GDB access failures (default).",
            "Everything: every prepared GDB access string + result, and step-by-step traversal (e.g. how 'next' is resolved at each hop)."
          ],
          "description": "Verbosity of the Debug Inspector Output channel (\"Debug Inspector: Show Log\")."
        },
        "rtosInspector.debugTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "cppdbg"
          ],
          "description": "Debug adapter types the tracker attaches to. Use 'cppdbg' for GDB."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
