{
  "//": "Extension'a NE izleyeceğini bu dosya söyler. Yapını bilmez; her şey burada.",

  "threads": {
    "//": "mode: 'linked_list' (root baş pointer + next alanı) veya 'array' (root dizi + count).",
    "//root": "root herhangi bir C ifadesi olabilir: 'head', 'g_sys.list', 'g_kernel.pools[0]->thread_list' ...",

    "mode": "linked_list",
    "root": "g_kernel.pools[0]->thread_list",
    "next": "next",
    "max": 1024,
    "fields": [
      { "label": "ID",          "expr": "id" },
      { "label": "Name",        "expr": "name" },
      { "label": "State",       "expr": "state" },
      { "label": "Priority",    "expr": "prio" },
      { "label": "Stack Start", "expr": "stack_base" },
      { "label": "Stack Size",  "expr": "stack_size" }
    ]
  },

  "semaphores": {
    "mode": "linked_list",
    "root": "g_kernel.pools[0]->sem_list",
    "next": "next",
    "fields": [
      { "label": "ID",         "expr": "id" },
      { "label": "Count",      "expr": "count" },
      { "label": "Max",        "expr": "max_count" },
      { "label": "Waiting",    "expr": "waiting" },
      { "label": "Discipline", "expr": "discipline" }
    ]
  },

  "//array_ornegi": {
    "mode": "array",
    "root": "g_threads",
    "count": "g_thread_count",
    "access": ".",
    "fields": [ { "label": "ID", "expr": "id" }, { "label": "Name", "expr": "name" } ]
  }
}
