# Local portable toolchain downloaded for building (not part of the project)
.tools/

# Personal Claude Code overrides (machine-specific; not part of the project)
.claude/settings.local.json
.claude/launch.json

# Node / build artifacts
node_modules/
extension/out/
*.log

# Test workspace build outputs (keep the folder, ignore artifacts)
test-workspace/build/*
!test-workspace/build/.gitkeep
test-workspace/*.exe
test-workspace/*.o

# Personal debug configs: contain a machine-specific toolchain path, never commit.
# See test-workspace/.vscode/*.example.json for portable templates.
test-workspace/.vscode/launch.json
test-workspace/.vscode/tasks.json

# Export output from the panel's "Export JSON" button
debug-inspector-export.json
